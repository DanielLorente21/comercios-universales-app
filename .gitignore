# ══════════════════════════════════════════════════════
#  .gitignore — / Comercios Universales
#  ⚠️  NO elimines las secciones marcadas como CRÍTICAS
# ══════════════════════════════════════════════════════

# ── CRÍTICO: Variables de entorno ──────────────────────
# Estos archivos contienen API keys y contraseñas
.env
.env.local
.env.production
.env.staging
.env*.local


# ── CRÍTICO: Credenciales Firebase / GSoogle ────────────
# Nunca subir estos archivos a ningún repositorio
google-services.json
GoogleService-Info.plist
serviceAccountKey.json
firebase-adminsdk*.json
*.credentials.json

# ── CRÍTICO: Scripts internos con datos sensibles ──────
# Contienen códigos reales de empleados y lógica interna
stress_test.js
monitor.js

# ── Dependencias ───────────────────────────────────────
node_modules/

# ── Expo ───────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ── Native (generado automáticamente) ─────────────────
/ios
/android
.kotlin/

# ── Certificados y llaves nativas ─────────────────────
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ── Metro bundler ──────────────────────────────────────
.metro-health-check*

# ── Logs de debug ──────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
firebase-debug.log
firebase-debug.*.log

# ── Sistema operativo ──────────────────────────────────
.DS_Store
Thumbs.db

# ── TypeScript ─────────────────────────────────────────
*.tsbuildinfo

# Service Account Keys (cualquier nombre)
*adminsdk*.json
permisoapplorenti*.json