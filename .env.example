# ══════════════════════════════════════════════════════
#  .env.example — SoluControl
#
#  ✅ ESTE archivo SÍ se sube a GitHub (no tiene valores reales)
#  ❌ El archivo .env NUNCA se sube a GitHub
#
#  Para usar: copia este archivo, renómbralo a .env
#  y rellena los valores reales.
# ══════════════════════════════════════════════════════

# ── Firebase ───────────────────────────────────────────
# Obtén estos valores en: Firebase Console > Configuración del proyecto
EXPO_PUBLIC_FIREBASE_API_KEY=tu_firebase_api_key_aqui

# ── Google Drive / Sheets ──────────────────────────────
# Obtén la API key en: Google Cloud Console > APIs & Services > Credentials
EXPO_PUBLIC_DRIVE_API_KEY=tu_drive_api_key_aqui

# ── Google Sheets ──────────────────────────────────────
# Es el ID que aparece en la URL de tu hoja:
# https://docs.google.com/spreadsheets/d/[ESTE_ES_EL_ID]/edit
EXPO_PUBLIC_SHEET_ID=tu_sheet_id_aqui
